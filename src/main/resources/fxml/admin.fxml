<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.unibl.etf.ui.controller.AdminController">
   <top>
       <HBox alignment="CENTER_LEFT"
             minHeight="-Infinity"
             minWidth="200.0"
             prefHeight="50.0"
             BorderPane.alignment="CENTER">
          
           <Label text="dock-sim-admin" />
           <Region HBox.hgrow="ALWAYS" />
         <padding>
            <Insets left="10.0" right="10.0" />
         </padding>
       </HBox>
   </top>
   <left>
      <ScrollPane hbarPolicy="NEVER">
         <BorderPane.margin>
            <Insets bottom="10.0" left="10.0" />
         </BorderPane.margin>
         <VBox alignment="TOP_CENTER" prefWidth="150.0" spacing="20.0">
            <Label text="Terminals" />
            <VBox fx:id="terminalsVBox" alignment="TOP_CENTER" spacing="5.0" />
            <Label layoutX="60.0" layoutY="10.0" text="Tools" />
         </VBox>
      </ScrollPane>
   </left>
   <center>
      <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0">
         <HBox spacing="10.0">
            <padding>
               <Insets left="10.0" right="10.0" />
            </padding>
            <VBox alignment="CENTER_LEFT" style="-fx-border-color: gray;" HBox.hgrow="ALWAYS">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <Label text="Total ships:" />
               <Label fx:id="totalShipsLabel">
                  <font>
                     <Font size="24.0" />
                  </font>
               </Label>
            </VBox>
            <VBox alignment="CENTER_LEFT" style="-fx-border-color: gray;" HBox.hgrow="ALWAYS">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <Label text="Free docks:" />
               <Label fx:id="freeDocksLabel">
                  <font>
                     <Font size="24.0" />
                  </font>
               </Label>
               <HBox alignment="CENTER_LEFT" fillHeight="false">
                  <Label text="of total " />
                  <Label fx:id="totalDocksLabel" />
               </HBox>
            </VBox>
            <VBox alignment="CENTER_LEFT" style="-fx-border-color: gray;" HBox.hgrow="ALWAYS">
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <Label text="State ships:" />
               <Label fx:id="totalStateShipsLabel">
                  <font>
                     <Font size="24.0" />
                  </font>
               </Label>
            </VBox>
         </HBox>
         <HBox alignment="CENTER_LEFT">
            <padding>
               <Insets left="10.0" right="10.0" />
            </padding>
            <VBox.margin>
               <Insets bottom="10.0" top="10.0" />
            </VBox.margin>
            <Label fx:id="selectedTerminalLabel" text="&lt;Select a terminal&gt;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="addShipBtn" onAction="#onAddShipAction" text="Add ship" />
         </HBox>
         <TableView fx:id="tableView" minHeight="-Infinity" minWidth="-Infinity" VBox.vgrow="ALWAYS">
            <columns>
               <TableColumn editable="false" prefWidth="100.0" text="Name" />
               <TableColumn editable="false" prefWidth="100.0" text="IMO" />
               <TableColumn editable="false" prefWidth="100.0" text="Type" />
               <TableColumn editable="false" prefWidth="100.0" text="Reg. number" />
               <TableColumn editable="false" prefWidth="100.0" resizable="false" text="Actions" />
            </columns>
            <VBox.margin>
               <Insets bottom="10.0" left="10.0" right="10.0" />
            </VBox.margin>
            <columnResizePolicy>
               <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
         </TableView>
      </VBox>
   </center>
   <bottom>
        <Button onAction="#onStartSimulationAction" text="Start simulation" BorderPane.alignment="CENTER_RIGHT">
         <BorderPane.margin>
            <Insets bottom="10.0" right="10.0" />
         </BorderPane.margin>
      </Button>
   </bottom>
</BorderPane>
